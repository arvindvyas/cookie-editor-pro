{
  "manifest_version": 3,
  "name": "Cookie Editor Pro — View, Edit, Clean & Manage Cookies",
  "version": "1.1.0",
  "description": "View, search, edit, delete, protect & back up cookies — including partitioned/isolated cookies. Allow/block lists + auto-clean. 100% local.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cookie Editor Pro",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": ["cookies", "storage", "tabs"],
  "host_permissions": ["<all_urls>"]
}
